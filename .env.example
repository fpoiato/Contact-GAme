# Copy to terraform.tfvars and fill in values

aws_region   = "us-east-1"
project_name = "contact-game"
environment  = "prod"

# CDK_DEFAULT_ACCOUNT=your-account-id
# CDK_DEFAULT_REGION=us-east-1

# GitHub Actions secrets:
# AWS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/contact-game-github-actions

# CodePipeline name: contact-game-pipeline
# CodeStar connection to GitHub required for source stage
